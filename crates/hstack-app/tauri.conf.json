{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HStack",
  "version": "0.1.0",
  "identifier": "com.antoine.hstack",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix ../../frontend",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "HStack",
        "width": 400,
        "height": 700,
        "minWidth": 320,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
